{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "npm",
    "pep621",
    "dockerfile",
    "helmv3",
    "helm-values"
  ],
  "packageRules": [
    {
      "description": "Group npm non-major updates together",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm non-major dependencies"
    },
    {
      "description": "Group Python non-major updates together",
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Python non-major dependencies"
    }
  ]
}
